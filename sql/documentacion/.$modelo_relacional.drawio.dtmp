<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.0.3 Chrome/140.0.7339.249 Electron/38.7.0 Safari/537.36" version="29.0.3">
  <diagram name="Modelo Relacional - TechManage 1.0" id="modelo-relacional">
    <mxGraphModel dx="443" dy="945" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="prod" value="PRODUCTOS&#xa;────────────────────────────────&#xa;id_producto INT PK (AI)&#xa;nombre VARCHAR(100) NOT NULL&#xa;descripcion TEXT&#xa;precio_venta DECIMAL(10,2) NOT NULL&#xa;categoria VARCHAR(50)&#xa;fecha_creacion DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;strokeColor=#2D7600;fontStyle=0;align=left;spacingLeft=10;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="40" y="40" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="prov" value="PROVEEDORES&#xa;────────────────────────────────&#xa;id_proveedor INT PK (AI)&#xa;nombre VARCHAR(100) NOT NULL&#xa;email VARCHAR(100) UNIQUE&#xa;telefono VARCHAR(20)&#xa;direccion VARCHAR(200)&#xa;contacto VARCHAR(100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;strokeColor=#2D7600;fontStyle=0;align=left;spacingLeft=10;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="40" y="220" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="prod_prov" value="PRODUCTOS_PROVEEDORES&#xa;────────────────────────────────&#xa;id_pp INT PK (AI)&#xa;id_producto INT FK (NOT NULL)&#xa;id_proveedor INT FK (NOT NULL)&#xa;precio_compra DECIMAL(10,2) NOT NULL&#xa;fecha_inicio DATE&#xa;──&#xa;UNIQUE(id_producto, id_proveedor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=0;align=left;spacingLeft=10" parent="1" vertex="1">
          <mxGeometry x="340" y="100" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="rel1a" value="" style="endArrow=classic;html=1;strokeWidth=2" parent="1" source="prod" target="prod_prov" edge="1">
