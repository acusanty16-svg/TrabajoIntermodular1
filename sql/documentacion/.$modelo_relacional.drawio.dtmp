          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="notas" value="INTEGRIDAD REFERENCIAL&#xa;────────────────────────────────&#xa;&#xa;PRODUCTOS_PROVEEDORES:&#xa;- id_producto → PRODUCTOS (CASCADE)&#xa;- id_proveedor → PROVEEDORES (CASCADE)&#xa;&#xa;INVENTARIO_TIENDA:&#xa;- id_producto → PRODUCTOS (CASCADE)&#xa;- id_tienda → TIENDA (CASCADE)&#xa;&#xa;VENTAS:&#xa;- id_cliente → CLIENTES (SET NULL)&#xa;- id_tienda → TIENDA (RESTRICT)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#60a917;strokeColor=#2D7600;align=left;spacingLeft=10;spacingTop=10;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="40" y="400" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="leyenda" value="LEYENDA&#xa;────────────────────────────────&#xa;PK = Clave Primaria&#xa;FK = Clave Foránea&#xa;AI = Auto Increment&#xa;UNIQUE = Valor único&#xa;NOT NULL = Obligatorio" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#60a917;strokeColor=#2D7600;align=left;spacingLeft=10;spacingTop=10;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="40" y="640" width="200" height="100" as="geometry" />
