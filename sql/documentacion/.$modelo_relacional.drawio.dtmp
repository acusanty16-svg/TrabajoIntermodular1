        <mxCell id="rel1b" value="" style="endArrow=classic;html=1;strokeWidth=2" parent="1" source="prov" target="prod_prov" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tienda" value="TIENDA&#xa;────────────────────────────────&#xa;id_tienda INT PK (AI)&#xa;nombre VARCHAR(100) NOT NULL&#xa;direccion VARCHAR(200)&#xa;telefono VARCHAR(20)&#xa;email VARCHAR(100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;align=left;spacingLeft=10" parent="1" vertex="1">
          <mxGeometry x="660" y="40" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="inv_tienda" value="INVENTARIO_TIENDA&#xa;────────────────────────────────&#xa;id_inventario INT PK (AI)&#xa;id_producto INT FK (NOT NULL)&#xa;id_tienda INT FK (NOT NULL)&#xa;cantidad_stock INT NOT NULL DEFAULT 0&#xa;stock_minimo INT NOT NULL DEFAULT 5&#xa;ultima_actualizacion DATETIME&#xa;──&#xa;UNIQUE(id_producto, id_tienda)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=0;align=left;spacingLeft=10" parent="1" vertex="1">
          <mxGeometry x="660" y="180" width="260" height="150" as="geometry" />
