          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="clientes" value="CLIENTES&#xa;────────────────────────────────&#xa;id_cliente INT PK (AI)&#xa;nombre VARCHAR(100) NOT NULL&#xa;email VARCHAR(100) UNIQUE&#xa;telefono VARCHAR(20)&#xa;direccion VARCHAR(200)&#xa;dni VARCHAR(20) UNIQUE NOT NULL&#xa;fecha_registro DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;align=left;spacingLeft=10" parent="1" vertex="1">
          <mxGeometry x="660" y="380" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ventas" value="VENTAS&#xa;────────────────────────────────&#xa;id_venta INT PK (AI)&#xa;id_cliente INT FK&#xa;id_tienda INT FK (NOT NULL)&#xa;fecha_venta DATETIME&#xa;total DECIMAL(10,2) NOT NULL&#xa;metodo_pago VARCHAR(50) NOT NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0;align=left;spacingLeft=10" parent="1" vertex="1">
